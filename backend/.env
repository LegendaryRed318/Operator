# Jarvis Operator Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit actual API keys to version control

# =============================================================================
# API KEYS - REQUIRED FOR CLOUD FALLBACK
# =============================================================================

# Gemini API Key for complex task fallback (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
USE_GEMINI_FALLBACK=true

# =============================================================================
# OLLAMA CONFIGURATION
# =============================================================================

OLLAMA_URL=http://localhost:11434

# Custom Ollama models path (if not using default)
# OLLAMA_MODELS=D:/OllamaModels/.ollama/models

# =============================================================================
# VOICE SYNTHESIS (Optional - browser TTS works without these)
# =============================================================================

# ElevenLabs API Key for voice synthesis (optional)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
USE_ELEVENLABS=false

# =============================================================================
# JARVIS MODE - small or homelab
# =============================================================================

# small = current machine, conservative limits
# homelab = dedicated server, full power
JARVIS_MODE=small

# =============================================================================
# PATHS (usually don't need to change these)
# =============================================================================

OPERATOR_DB_PATH=
OPERATOR_LOGS_PATH=
OPERATOR_VAULT_PATH=
OPERATOR_VAULT_EXTERNAL=E:/JarvisVault

# =============================================================================
# NETWORKING
# =============================================================================

# Enable remote access via Tailscale VPN (homelab mode)
ENABLE_REMOTE_ACCESS=false
# TAILSCALE_AUTHKEY=tskey-auth-xxxxx

# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================

TELEGRAM_BOT_TOKEN=your_new_token_here
TELEGRAM_CHAT_ID=8003159796
